generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id                 String              @id @default(cuid())
  slug               String              @unique
  title              String
  status             String              @default("PAUSED")
  accessCodeHash     String
  currentSequence    Int                 @default(0)
  finaleState        String              @default("SEALED")
  finaleTeaser       String?
  finaleRequirements String              @default("[]")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  chapters           Chapter[]
  artifacts          Artifact[]
  mapLocations       MapLocation[]
  mapRoutes          MapRoute[]
  sideQuests         SideQuest[]
  events             ProgressEvent[]
  snapshots          CampaignSnapshot[]
  awards             ArtifactAward[]
  journalEntries     JournalEntry[]
  auditLogs          AdminAuditLog[]
  saveStates         SaveStateSnapshot[]
  playerAccesses     PlayerAccess[]
  preparedActions    PreparedAction[]
  commandExecutions  CommandExecution[]
  playerPresences    PlayerPresence[]
}

model PlayerAccess {
  id            String           @id @default(cuid())
  campaignId    String
  tokenHash     String           @unique
  label         String?
  expiresAt     DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime         @default(now())
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  audio         AudioPreference?
  presences     PlayerPresence[]
  viewedContent ViewedContent[]

  @@index([campaignId])
}

model PlayerPresence {
  id                   String       @id @default(cuid())
  campaignId           String
  playerAccessId       String
  deviceId             String
  route                String?
  visibility           String?
  connectedAt          DateTime     @default(now())
  lastHeartbeatAt      DateTime     @default(now())
  disconnectedAt       DateTime?
  acknowledgedSequence Int          @default(0)
  campaign             Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  playerAccess         PlayerAccess @relation(fields: [playerAccessId], references: [id], onDelete: Cascade)

  @@unique([campaignId, deviceId])
  @@index([campaignId, lastHeartbeatAt])
}

model GameMasterUser {
  id                      String                              @id @default(cuid())
  username                String                              @unique
  passwordHash            String
  role                    String                              @default("CAPTAIN_CREATOR")
  capabilities            String                              @default("[]")
  createdAt               DateTime                            @default(now())
  sessions                GameMasterSession[]
  auditLogs               AdminAuditLog[]
  platformRoles           PlatformRoleAssignment[]
  visionWaypoints         VisionWaypoint[]                    @relation("VisionWaypointOwner")
  visionVersions          VisionWaypointVersion[]             @relation("VisionVersionCreator")
  visionPublishedVersions VisionWaypointVersion[]             @relation("VisionVersionPublisher")
  visionPublications      VisionWaypointPublication[]         @relation("VisionPublicationPublisher")
  visionProfiles          VisionWaypointVerificationProfile[] @relation("VisionProfileOwner")
  companionDevices        CompanionDevice[]                   @relation("CompanionDeviceOwner")
  pairingSessions         PairingSession[]                    @relation("PairingSessionOwner")
}

model GameMasterSession {
  id        String         @id
  userId    String
  csrfToken String
  expiresAt DateTime
  createdAt DateTime       @default(now())
  user      GameMasterUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Chapter {
  id                  String         @id @default(cuid())
  campaignId          String
  ordinal             Int
  state               String         @default("LOCKED")
  contentId           String
  revealedAt          DateTime?
  solvedAt            DateTime?
  safeTeaser          String?
  relatedMapKey       String?
  relatedArtifactKey  String?
  relatedSideQuestKey String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  campaign            Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  content             ChapterContent @relation(fields: [contentId], references: [id])
  clues               Clue[]
  hints               Hint[]

  @@unique([campaignId, ordinal])
  @@index([campaignId, state])
}

model ChapterContent {
  id              String    @id @default(cuid())
  version         Int       @default(1)
  title           String
  narrative       String
  objective       String
  developmentOnly Boolean   @default(true)
  createdAt       DateTime  @default(now())
  chapters        Chapter[]
}

model Clue {
  id        String  @id @default(cuid())
  chapterId String
  ordinal   Int
  body      String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, ordinal])
}

model Hint {
  id         String    @id @default(cuid())
  chapterId  String
  ordinal    Int
  body       String
  releasedAt DateTime?
  chapter    Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, ordinal])
}

model Artifact {
  id                   String          @id @default(cuid())
  campaignId           String
  key                  String
  name                 String
  description          String
  safeName             String?
  state                String          @default("UNKNOWN")
  category             String          @default("RELIC")
  discoveryText        String?
  silhouetteLabel      String?
  displayX             Float           @default(50)
  displayY             Float           @default(50)
  assemblyGroup        String?
  assemblyPosition     String?
  connectedArtifactKey String?
  chapterOrdinal       Int?
  campaign             Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  awards               ArtifactAward[]

  @@unique([campaignId, key])
}

model ArtifactAward {
  id         String   @id @default(cuid())
  campaignId String
  artifactId String
  eventId    String?  @unique
  awardedAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  artifact   Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, artifactId])
}

model SideQuest {
  id                String               @id @default(cuid())
  campaignId        String
  key               String
  title             String
  state             String               @default("UNDISCOVERED")
  safeTeaser        String?
  description       String?
  rewardType        String?
  rewardLabel       String?
  completionSummary String?
  chapterOrdinal    Int?
  mapLocationKey    String?
  artifactKey       String?
  completedAt       DateTime?
  campaign          Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  objectives        SideQuestObjective[]

  @@unique([campaignId, key])
}

model SideQuestObjective {
  id          String    @id @default(cuid())
  sideQuestId String
  ordinal     Int
  body        String
  complete    Boolean   @default(false)
  sideQuest   SideQuest @relation(fields: [sideQuestId], references: [id], onDelete: Cascade)

  @@unique([sideQuestId, ordinal])
}

model JournalEntry {
  id             String    @id @default(cuid())
  campaignId     String
  title          String
  body           String
  kind           String    @default("ANNOTATION")
  eventId        String?   @unique
  chapterOrdinal Int?
  releasedAt     DateTime?
  createdAt      DateTime  @default(now())
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, releasedAt])
}

model MapLocation {
  id             String    @id @default(cuid())
  campaignId     String
  key            String
  name           String
  safeLabel      String?
  regionLabel    String
  locationType   String    @default("STORY")
  state          String    @default("UNKNOWN")
  description    String?
  exactness      String    @default("APPROXIMATE")
  chapterOrdinal Int?
  sideQuestKey   String?
  x              Float
  y              Float
  mobileX        Float?
  mobileY        Float?
  revealedAt     DateTime?
  completedAt    DateTime?
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, key])
}

model MapRoute {
  id         String    @id @default(cuid())
  campaignId String
  key        String
  fromKey    String
  toKey      String
  ordinal    Int
  state      String    @default("HIDDEN")
  annotation String?
  revealedAt DateTime?
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, key])
  @@index([campaignId, ordinal])
}

model ProgressEvent {
  id              String   @id @default(cuid())
  campaignId      String
  type            String
  payload         String
  actor           String
  sequence        Int
  version         Int      @default(1)
  releaseAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  reversesEventId String?
  supersededById  String?
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sequence])
  @@index([campaignId, releaseAt])
}

model CampaignSnapshot {
  id         String   @id @default(cuid())
  campaignId String
  sequence   Int
  version    Int      @default(1)
  state      String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sequence])
}

model AdminAuditLog {
  id            String          @id @default(cuid())
  campaignId    String
  userId        String?
  action        String
  metadata      String
  correlationId String?
  outcome       String          @default("SUCCEEDED")
  reason        String?
  createdAt     DateTime        @default(now())
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user          GameMasterUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
}

model PreparedAction {
  id               String    @id @default(cuid())
  campaignId       String
  command          String
  targetKey        String?
  payload          String
  status           String    @default("PREPARED")
  expectedSequence Int
  scheduledFor     DateTime?
  preparedBy       String
  preparedAt       DateTime  @default(now())
  executedAt       DateTime?
  cancelledAt      DateTime?
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status, scheduledFor])
}

model CommandExecution {
  id               String    @id @default(cuid())
  campaignId       String
  idempotencyKey   String
  command          String
  expectedSequence Int
  correlationId    String
  status           String
  result           String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, idempotencyKey])
  @@index([campaignId, createdAt])
}

model AudioPreference {
  id                  String       @id @default(cuid())
  playerAccessId      String       @unique
  muted               Boolean      @default(false)
  masterVolume        Float        @default(0.45)
  ambientVolume       Float        @default(0.25)
  effectsVolume       Float        @default(0.55)
  motionMode          String       @default("SYSTEM")
  textScale           Float        @default(1)
  ambientEffects      Boolean      @default(true)
  textureIntensity    Float        @default(1)
  fullscreenPreferred Boolean      @default(false)
  updatedAt           DateTime     @updatedAt
  playerAccess        PlayerAccess @relation(fields: [playerAccessId], references: [id], onDelete: Cascade)
}

model ViewedContent {
  id             String       @id @default(cuid())
  playerAccessId String
  contentType    String
  contentKey     String
  viewedAt       DateTime     @default(now())
  playerAccess   PlayerAccess @relation(fields: [playerAccessId], references: [id], onDelete: Cascade)

  @@unique([playerAccessId, contentType, contentKey])
  @@index([playerAccessId, viewedAt])
}

model ContentVersion {
  id          String    @id @default(cuid())
  key         String
  version     Int
  checksum    String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([key, version])
}

model SaveStateSnapshot {
  id         String   @id @default(cuid())
  campaignId String
  sequence   Int
  state      String
  reason     String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, sequence])
}

model ViewedCeremony {
  id         String   @id @default(cuid())
  campaignId String
  deviceId   String
  eventId    String
  viewedAt   DateTime @default(now())

  @@unique([campaignId, deviceId, eventId])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  fingerprint String
  succeeded   Boolean
  createdAt   DateTime @default(now())

  @@index([fingerprint, createdAt])
}

// Tall Tale Studio is deliberately additive. The original Campaign models above
// continue to power the existing Forever Treasure experience while authored tales
// use an immutable publish-and-session model.
model TallTale {
  id                       String                 @id @default(cuid())
  slug                     String                 @unique
  title                    String
  subtitle                 String?
  shortDescription         String?
  longDescription          String?
  coverAssetId             String?
  theme                    String                 @default("CARTOGRAPHERS_TABLE")
  status                   String                 @default("DRAFT")
  visibility               String                 @default("PRIVATE")
  creatorId                String
  currentDraftRevisionId   String?
  latestPublishedVersionId String?
  forkedFromTaleId         String?
  forkedFromVersionId      String?
  playerCountMin           Int                    @default(1)
  playerCountMax           Int                    @default(4)
  estimatedDuration        Int?
  contentWarnings          String?
  sortOrder                Int                    @default(0)
  featured                 Boolean                @default(false)
  archivedAt               DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  drafts                   TaleDraft[]
  versions                 PublishedTaleVersion[]
  assets                   TaleAsset[]
  collections              TaleAssetCollection[]
  locations                TaleLocation[]
  storyArtifacts           TaleArtifact[]
  sessions                 TaleSession[]
  visionBindings           StoryWaypointBinding[]
  visionAttempts           VerificationAttempt[]

  @@index([status, visibility, sortOrder])
  @@index([creatorId, updatedAt])
}

model TaleDraft {
  id                        String        @id @default(cuid())
  taleId                    String
  revisionNumber            Int           @default(1)
  basedOnPublishedVersionId String?
  createdBy                 String
  autosaveVersion           Int           @default(1)
  validationState           String        @default("NOT_VALIDATED")
  validationSummary         String        @default("{}")
  lastValidatedAt           DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  tale                      TallTale      @relation(fields: [taleId], references: [id], onDelete: Cascade)
  chapters                  TaleChapter[]

  @@unique([taleId, revisionNumber])
  @@index([taleId, updatedAt])
}

model TaleChapter {
  id                String       @id @default(cuid())
  draftRevisionId   String
  title             String
  subtitle          String?
  description       String?
  orderIndex        Int
  coverAssetId      String?
  estimatedDuration Int?
  entryBlockId      String?
  completionBlockId String?
  isOptional        Boolean      @default(false)
  metadata          String       @default("{}")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  draft             TaleDraft    @relation(fields: [draftRevisionId], references: [id], onDelete: Cascade)
  blocks            StoryBlock[]

  @@unique([draftRevisionId, orderIndex])
  @@index([draftRevisionId])
}

model StoryBlock {
  id            String                @id @default(cuid())
  chapterId     String
  blockType     String
  title         String
  internalLabel String?
  orderIndex    Int
  configuration String                @default("{}")
  presentation  String                @default("{}")
  completion    String                @default("{}")
  nextBlockId   String?
  creatorNotes  String?
  isEnabled     Boolean               @default(true)
  schemaVersion Int                   @default(1)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  chapter       TaleChapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  outgoing      BlockConnection[]     @relation("BlockConnectionSource")
  incoming      BlockConnection[]     @relation("BlockConnectionTarget")
  visionBinding StoryWaypointBinding?

  @@unique([chapterId, orderIndex])
  @@index([chapterId, blockType])
}

model BlockConnection {
  id                  String     @id @default(cuid())
  sourceBlockId       String
  targetBlockId       String
  connectionType      String     @default("DEFAULT")
  conditionExpression String?
  label               String?
  orderIndex          Int        @default(0)
  createdAt           DateTime   @default(now())
  source              StoryBlock @relation("BlockConnectionSource", fields: [sourceBlockId], references: [id], onDelete: Cascade)
  target              StoryBlock @relation("BlockConnectionTarget", fields: [targetBlockId], references: [id], onDelete: Cascade)

  @@unique([sourceBlockId, targetBlockId, connectionType])
  @@index([targetBlockId])
}

model PublishedTaleVersion {
  id              String        @id @default(cuid())
  taleId          String
  versionNumber   Int
  versionLabel    String
  publishedAt     DateTime      @default(now())
  publishedBy     String
  releaseNotes    String?
  contentSnapshot String
  schemaVersion   Int           @default(1)
  checksum        String
  isCurrent       Boolean       @default(true)
  tale            TallTale      @relation(fields: [taleId], references: [id], onDelete: Cascade)
  sessions        TaleSession[]

  @@unique([taleId, versionNumber])
  @@index([taleId, isCurrent])
}

model TaleAsset {
  id               String                    @id @default(cuid())
  taleId           String
  mediaType        String
  displayName      String
  description      String?
  originalFilename String
  currentVariantId String?
  mimeType         String
  fileSize         Int
  width            Int?
  height           Int?
  duration         Float?
  checksum         String
  createdBy        String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deletedAt        DateTime?
  tale             TallTale                  @relation(fields: [taleId], references: [id], onDelete: Cascade)
  variants         TaleAssetVariant[]
  tags             TaleAssetTagLink[]
  roles            TaleAssetRole[]
  collectionItems  TaleAssetCollectionItem[]

  @@unique([taleId, checksum])
  @@index([taleId, mediaType, deletedAt])
}

model TaleAssetVariant {
  id              String    @id @default(cuid())
  assetId         String
  role            String
  storageKey      String    @unique
  mimeType        String
  fileSize        Int
  width           Int?
  height          Int?
  duration        Float?
  checksum        String
  processingState String    @default("READY")
  createdAt       DateTime  @default(now())
  asset           TaleAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, role, createdAt])
}

model TaleAssetTag {
  id        String             @id @default(cuid())
  taleId    String
  name      String
  createdAt DateTime           @default(now())
  assets    TaleAssetTagLink[]

  @@unique([taleId, name])
}

model TaleAssetTagLink {
  assetId String
  tagId   String
  asset   TaleAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag     TaleAssetTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@index([tagId])
}

model TaleAssetRole {
  id        String    @id @default(cuid())
  assetId   String
  role      String
  createdAt DateTime  @default(now())
  asset     TaleAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, role])
}

model TaleAssetCollection {
  id             String                    @id @default(cuid())
  taleId         String
  name           String
  description    String?
  collectionType String                    @default("GENERAL")
  locationId     String?
  artifactId     String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  tale           TallTale                  @relation(fields: [taleId], references: [id], onDelete: Cascade)
  items          TaleAssetCollectionItem[]

  @@unique([taleId, name])
}

model TaleAssetCollectionItem {
  id           String              @id @default(cuid())
  collectionId String
  assetId      String
  label        String?
  orderIndex   Int                 @default(0)
  metadata     String              @default("{}")
  createdAt    DateTime            @default(now())
  collection   TaleAssetCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  asset        TaleAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([collectionId, assetId, label])
  @@index([assetId])
}

model TaleLocation {
  id                      String    @id @default(cuid())
  taleId                  String
  name                    String
  slug                    String
  region                  String?
  generalDescription      String?
  playerFacingDescription String?
  captainNotes            String?
  mapAssetId              String?
  displayAssetId          String?
  referenceCollectionId   String?
  verificationProfile     String    @default("{}")
  orderIndex              Int       @default(0)
  archivedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  tale                    TallTale  @relation(fields: [taleId], references: [id], onDelete: Cascade)

  @@unique([taleId, slug])
  @@index([taleId, orderIndex])
}

model TaleArtifact {
  id                      String    @id @default(cuid())
  taleId                  String
  name                    String
  shortDescription        String?
  loreDescription         String?
  ordinaryGameObjectLabel String?
  artworkAssetId          String?
  revealVideoAssetId      String?
  modelAssetId            String?
  inventoryCategory       String    @default("RELIC")
  collectionGroup         String?
  sortOrder               Int       @default(0)
  persistentAfterUnlock   Boolean   @default(true)
  archivedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  tale                    TallTale  @relation(fields: [taleId], references: [id], onDelete: Cascade)

  @@index([taleId, sortOrder])
}

model TaleSession {
  id                   String                    @id @default(cuid())
  taleId               String
  publishedVersionId   String?
  ownerLabel           String?
  voyageName           String?
  captainId            String?
  accessTokenHash      String                    @unique
  status               String                    @default("ACTIVE")
  captainMode          String                    @default("CAPTAIN_CONTROLLED")
  configuration        String                    @default("{}")
  scheduleTimezone     String?
  plannedStartAt       DateTime?
  launchedAt           DateTime?
  cancelledAt          DateTime?
  abandonedAt          DateTime?
  concurrencyVersion   Int                       @default(0)
  historicalHidden     Boolean                   @default(false)
  archiveMetadata      String                    @default("{}")
  currentChapterId     String?
  currentBlockId       String?
  currentSequence      Int                       @default(0)
  previewMode          Boolean                   @default(false)
  draftRevisionId      String?
  previewSnapshot      String?
  variables            String                    @default("{}")
  inventory            String                    @default("[]")
  startedAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  completedAt          DateTime?
  expiresAt            DateTime?
  lastHeartbeatAt      DateTime?
  tale                 TallTale                  @relation(fields: [taleId], references: [id], onDelete: Cascade)
  version              PublishedTaleVersion?     @relation(fields: [publishedVersionId], references: [id])
  events               TaleSessionEvent[]
  verificationRequests TaleVerificationRequest[]
  helperPairings       TaleHelperPairing[]
  memberships          PlaythroughMembership[]
  invitations          Invitation[]
  revealStates         RevealState[]
  visionAttempts       VerificationAttempt[]

  @@index([taleId, status, previewMode])
  @@index([publishedVersionId, status])
}

model PlayerProfile {
  id                   String                  @id @default(cuid())
  username             String?                 @unique
  passwordHash         String?
  displayName          String
  status               String                  @default("ACTIVE")
  preferences          String                  @default("{}")
  claimedAt            DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  lastSeenAt           DateTime?
  sessions             PlayerIdentitySession[]
  memberships          PlaythroughMembership[]
  invitations          Invitation[]
  verificationAttempts VerificationAttempt[]

  @@index([status, displayName])
}

model PlayerIdentitySession {
  id              String        @id @default(cuid())
  playerProfileId String
  tokenHash       String        @unique
  csrfToken       String
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  lastSeenAt      DateTime      @default(now())
  revokedAt       DateTime?
  player          PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId, expiresAt])
}

model PlatformRoleAssignment {
  id        String         @id @default(cuid())
  accountId String
  role      String
  scopeType String         @default("GLOBAL")
  scopeId   String?
  grantedBy String?
  grantedAt DateTime       @default(now())
  revokedAt DateTime?
  account   GameMasterUser @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, role, scopeType, scopeId])
  @@index([role, scopeType, scopeId, revokedAt])
}

model PlaythroughMembership {
  id              String        @id @default(cuid())
  playthroughId   String
  playerProfileId String
  role            String        @default("PLAYER")
  status          String        @default("INVITED")
  crewRole        String?
  joinedAt        DateTime?
  removedAt       DateTime?
  completedAt     DateTime?
  pinnedAt        DateTime?
  hiddenAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  playthrough     TaleSession   @relation(fields: [playthroughId], references: [id], onDelete: Cascade)
  player          PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@unique([playthroughId, playerProfileId])
  @@index([playerProfileId, status, updatedAt])
}

model Invitation {
  id                   String            @id @default(cuid())
  playthroughId        String
  intendedPlayerId     String?
  tokenHash            String            @unique
  tokenPrefix          String
  shortCodeHash        String            @unique
  shortCodePrefix      String
  pinHash              String?
  recipientName        String
  status               String            @default("CREATED")
  deliveryMethods      String            @default("[]")
  expiresAt            DateTime
  maxRedemptions       Int               @default(1)
  redemptionCount      Int               @default(0)
  viewedAt             DateTime?
  acceptedAt           DateTime?
  declinedAt           DateTime?
  revokedAt            DateTime?
  lastValidatedAt      DateTime?
  replacesInvitationId String?           @unique
  createdBy            String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  playthrough          TaleSession       @relation(fields: [playthroughId], references: [id], onDelete: Cascade)
  intendedPlayer       PlayerProfile?    @relation(fields: [intendedPlayerId], references: [id], onDelete: SetNull)
  replaces             Invitation?       @relation("InvitationReplacement", fields: [replacesInvitationId], references: [id], onDelete: SetNull)
  replacement          Invitation?       @relation("InvitationReplacement")
  events               InvitationEvent[]

  @@index([playthroughId, status, expiresAt])
  @@index([intendedPlayerId, status])
}

model InvitationEvent {
  id           String     @id @default(cuid())
  invitationId String
  eventType    String
  actorType    String
  actorId      String?
  metadata     String     @default("{}")
  createdAt    DateTime   @default(now())
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId, createdAt])
}

model RevealState {
  id            String      @id @default(cuid())
  playthroughId String
  contentType   String
  contentKey    String
  status        String      @default("REVEALED")
  revealedBy    String?
  revealedAt    DateTime    @default(now())
  playthrough   TaleSession @relation(fields: [playthroughId], references: [id], onDelete: Cascade)

  @@unique([playthroughId, contentType, contentKey])
  @@index([playthroughId, revealedAt])
}

model PlatformAuditEvent {
  id            String   @id @default(cuid())
  actorType     String
  actorId       String?
  action        String
  resourceType  String
  resourceId    String
  outcome       String   @default("SUCCEEDED")
  correlationId String
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([actorType, actorId, createdAt])
  @@index([correlationId])
}

model TaleSessionEvent {
  id                    String      @id @default(cuid())
  sessionId             String
  publishedVersionId    String
  blockId               String?
  eventType             String
  sourceType            String
  sourceId              String?
  idempotencyKey        String      @unique
  payload               String      @default("{}")
  sequence              Int
  correlationId         String?
  verificationRequestId String?
  createdAt             DateTime    @default(now())
  session               TaleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId, createdAt])
}

model TaleVerificationRequest {
  id                    String                  @id @default(cuid())
  sessionId             String
  blockId               String
  providerType          String
  status                String                  @default("PENDING")
  requestedAt           DateTime                @default(now())
  resolvedAt            DateTime?
  expiresAt             DateTime?
  configurationSnapshot String                  @default("{}")
  providerCorrelationId String?
  satisfiedByEventId    String?
  session               TaleSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submissions           TaleVerificationEvent[]
  visionAttempts        VerificationAttempt[]

  @@index([sessionId, status, requestedAt])
  @@index([blockId, status])
}

model TaleVerificationEvent {
  id                 String                  @id @default(cuid())
  requestId          String
  eventId            String                  @unique
  idempotencyKey     String                  @unique
  schemaVersion      Int                     @default(1)
  providerType       String
  providerInstanceId String?
  result             String
  confidence         Float?
  evidence           String                  @default("{}")
  observedAt         DateTime
  accepted           Boolean                 @default(false)
  rejectionReason    String?
  createdAt          DateTime                @default(now())
  request            TaleVerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model TaleHelperPairing {
  id         String      @id @default(cuid())
  sessionId  String
  deviceId   String
  tokenHash  String      @unique
  status     String      @default("ACTIVE")
  expiresAt  DateTime
  lastSeenAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())
  session    TaleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
}

model VisionWaypoint {
  id           String                  @id @default(cuid())
  ownerId      String
  name         String
  description  String                  @default("")
  type         String
  locationTags String                  @default("[]")
  sharingScope String                  @default("PRIVATE")
  archivedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  owner        GameMasterUser          @relation("VisionWaypointOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  versions     VisionWaypointVersion[]
  bindings     StoryWaypointBinding[]
  attempts     VerificationAttempt[]

  @@index([ownerId, archivedAt, updatedAt])
  @@index([type, sharingScope])
}

model VisionWaypointVersion {
  id                       String                     @id @default(cuid())
  waypointId               String
  versionNumber            Int
  parentVersionId          String?
  lifecycleStatus          String                     @default("DRAFT")
  verificationProfile      String                     @default("BALANCED")
  packageSchemaVersion     Int                        @default(1)
  draftConfiguration       String                     @default("{}")
  packageArtifactReference String?
  compatibilityMetadata    String                     @default("{}")
  certificationReference   String?
  createdBy                String
  publishedBy              String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  publishedAt              DateTime?
  deprecatedAt             DateTime?
  waypoint                 VisionWaypoint             @relation(fields: [waypointId], references: [id], onDelete: Restrict)
  parentVersion            VisionWaypointVersion?     @relation("VisionVersionLineage", fields: [parentVersionId], references: [id], onDelete: SetNull)
  derivedVersions          VisionWaypointVersion[]    @relation("VisionVersionLineage")
  creator                  GameMasterUser             @relation("VisionVersionCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  publisher                GameMasterUser?            @relation("VisionVersionPublisher", fields: [publishedBy], references: [id], onDelete: Restrict)
  publication              VisionWaypointPublication?
  captureSessions          VisionCaptureSession[]
  recordingAssets          VisionRecordingAsset[]
  regions                  VisionRegion[]
  poseRegions              VisionPoseRegion[]
  hardNegativeSets         VisionHardNegativeSet[]
  buildJobs                VisionBuildJob[]
  buildArtifacts           VisionBuildArtifact[]
  certificationRuns        VisionCertificationRun[]
  testRuns                 VisionWaypointTestRun[]
  bindings                 StoryWaypointBinding[]
  attempts                 VerificationAttempt[]

  @@unique([waypointId, versionNumber])
  @@index([waypointId, lifecycleStatus, updatedAt])
  @@index([parentVersionId])
  @@index([publishedAt, deprecatedAt])
}

model VisionWaypointPublication {
  id                   String                @id @default(cuid())
  waypointVersionId    String                @unique
  packageHash          String
  packageSchemaVersion Int                   @default(1)
  publishedAt          DateTime              @default(now())
  publishedBy          String
  compatibilityRange   String                @default("{}")
  status               String                @default("ACTIVE")
  waypointVersion      VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Restrict)
  publisher            GameMasterUser        @relation("VisionPublicationPublisher", fields: [publishedBy], references: [id], onDelete: Restrict)

  @@index([packageHash])
  @@index([status, publishedAt])
}

model VisionCaptureSession {
  id                  String                      @id @default(cuid())
  sessionKey          String?                     @unique
  waypointVersionId   String
  purpose             String
  actorType           String
  actorId             String?
  companionVersion    String?
  protocolVersion     String?
  captureApi          String?
  captureResolution   String?
  frameRate           Float?
  durationMs          Int?
  hardwarePath        String?
  targetMetadata      String                      @default("{}")
  qualitySummary      String                      @default("{}")
  interruptionSummary String                      @default("{}")
  consentFlags        String                      @default("{}")
  retentionPolicy     String                      @default("DERIVED_ONLY")
  manifestVersion     Int                         @default(1)
  status              String                      @default("CREATED")
  failureReason       String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @default(now()) @updatedAt
  startedAt           DateTime?
  completedAt         DateTime?
  waypointVersion     VisionWaypointVersion       @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  recordingAssets     VisionRecordingAsset[]
  interruptions       VisionCaptureInterruption[]
  diagnosticBundles   VisionDiagnosticBundle[]

  @@index([waypointVersionId, purpose, createdAt])
  @@index([actorType, actorId, createdAt])
}

model VisionRecordingAsset {
  id                String                @id @default(cuid())
  waypointVersionId String
  captureSessionId  String?
  assetType         String
  storageReference  String
  contentHash       String
  fileSize          Int
  mediaType         String                @default("video/webm")
  manifestVersion   Int                   @default(1)
  artifactManifest  String                @default("{}")
  durationMs        Int?
  datasetPartition  String                @default("UNASSIGNED")
  truthLabel        String                @default("UNKNOWN")
  creatorLabel      String?
  qualitySummary    String                @default("{}")
  deletionStatus    String                @default("ACTIVE")
  createdAt         DateTime              @default(now())
  deletedAt         DateTime?
  waypointVersion   VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  captureSession    VisionCaptureSession? @relation(fields: [captureSessionId], references: [id], onDelete: SetNull)
  regions           VisionRegion[]

  @@unique([waypointVersionId, contentHash])
  @@index([captureSessionId])
  @@index([waypointVersionId, datasetPartition, truthLabel])
}

model VisionCaptureInterruption {
  id               String               @id @default(cuid())
  captureSessionId String
  code             String
  metadata         String               @default("{}")
  recoverable      Boolean              @default(true)
  occurredAt       DateTime             @default(now())
  captureSession   VisionCaptureSession @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)

  @@index([captureSessionId, occurredAt])
  @@index([code, occurredAt])
}

model VisionDiagnosticBundle {
  id                String                @id @default(cuid())
  captureSessionId  String?
  actorType         String
  actorId           String?
  bundleReference   String
  contentHash       String?
  fileSize          Int
  metadata          String                @default("{}")
  containsRawFrames Boolean               @default(false)
  consentAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime              @default(now())
  deletedAt         DateTime?
  captureSession    VisionCaptureSession? @relation(fields: [captureSessionId], references: [id], onDelete: SetNull)

  @@index([captureSessionId, createdAt])
  @@index([actorType, actorId, createdAt])
  @@index([expiresAt, deletedAt])
}

model VisionCapturePreference {
  id                  String   @id @default(cuid())
  ownerType           String
  ownerId             String
  deviceInstanceId    String
  rememberTarget      Boolean  @default(false)
  selectedTargetHash  String?
  hotkeyBinding       String   @default("Control+Alt+F9")
  hotkeyInteraction   String   @default("HOLD")
  hotkeyEnabled       Boolean  @default(false)
  previewEnabled      Boolean  @default(true)
  diagnosticRetention Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([ownerType, ownerId, deviceInstanceId])
  @@index([ownerType, ownerId, updatedAt])
}

model VisionRegion {
  id                String                @id @default(cuid())
  waypointVersionId String
  recordingAssetId  String?
  regionType        String
  coordinateSpace   String                @default("NORMALIZED_IMAGE")
  geometry          String
  semanticLabel     String?
  createdBy         String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  waypointVersion   VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  recordingAsset    VisionRecordingAsset? @relation(fields: [recordingAssetId], references: [id], onDelete: Cascade)

  @@index([waypointVersionId, regionType])
  @@index([recordingAssetId])
}

model VisionPoseRegion {
  id                    String                @id @default(cuid())
  waypointVersionId     String
  coordinateSystem      String
  shapeType             String
  parameters            String
  classification        String
  orientationRules      String                @default("{}")
  targetVisibilityRules String                @default("{}")
  authoringSource       String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  waypointVersion       VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)

  @@index([waypointVersionId, classification])
}

model VisionHardNegativeSet {
  id                         String                @id @default(cuid())
  waypointVersionId          String
  name                       String
  classification             String
  strongestConfuserReference String?
  metadata                   String                @default("{}")
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  waypointVersion            VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)

  @@unique([waypointVersionId, name])
  @@index([waypointVersionId, classification])
}

model VisionBuildJob {
  id                String                @id @default(cuid())
  waypointVersionId String
  executionTarget   String                @default("LOCAL")
  engineMetadata    String                @default("{}")
  processingStage   String                @default("QUEUED")
  status            String                @default("QUEUED")
  progress          Float                 @default(0)
  logSummary        String                @default("[]")
  outputSummary     String                @default("{}")
  failureCode       String?
  createdAt         DateTime              @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  waypointVersion   VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  artifacts         VisionBuildArtifact[]

  @@index([waypointVersionId, status, createdAt])
}

model VisionBuildArtifact {
  id                String                   @id @default(cuid())
  waypointVersionId String
  buildJobId        String?
  artifactType      String
  storageReference  String
  contentHash       String
  fileSize          Int
  schemaVersion     Int                      @default(1)
  createdAt         DateTime                 @default(now())
  waypointVersion   VisionWaypointVersion    @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  buildJob          VisionBuildJob?          @relation(fields: [buildJobId], references: [id], onDelete: SetNull)
  certificationRuns VisionCertificationRun[]

  @@unique([waypointVersionId, contentHash, artifactType])
  @@index([buildJobId])
}

model VisionCertificationRun {
  id                      String                  @id @default(cuid())
  waypointVersionId       String
  buildArtifactId         String?
  validationPartitionHash String
  lockedTestPartitionHash String
  thresholds              String                  @default("{}")
  profile                 String
  metrics                 String                  @default("{}")
  observedFalseResults    String                  @default("{}")
  reliabilityGrade        String
  approvedRuntimeModes    String                  @default("[]")
  reviewerId              String?
  reportReference         String?
  createdAt               DateTime                @default(now())
  completedAt             DateTime?
  waypointVersion         VisionWaypointVersion   @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  buildArtifact           VisionBuildArtifact?    @relation(fields: [buildArtifactId], references: [id], onDelete: SetNull)
  testRuns                VisionWaypointTestRun[]

  @@index([waypointVersionId, createdAt])
  @@index([buildArtifactId])
}

model VisionWaypointTestRun {
  id                 String                  @id @default(cuid())
  waypointVersionId  String
  certificationRunId String?
  testType           String
  expectedResult     String
  actualResult       String?
  status             String                  @default("PENDING")
  evidenceReference  String?
  createdAt          DateTime                @default(now())
  completedAt        DateTime?
  waypointVersion    VisionWaypointVersion   @relation(fields: [waypointVersionId], references: [id], onDelete: Cascade)
  certificationRun   VisionCertificationRun? @relation(fields: [certificationRunId], references: [id], onDelete: SetNull)

  @@index([waypointVersionId, testType, status])
  @@index([certificationRunId])
}

model VisionWaypointVerificationProfile {
  id            String         @id @default(cuid())
  ownerId       String
  name          String
  schemaVersion Int            @default(1)
  requirements  String         @default("{}")
  archivedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         GameMasterUser @relation("VisionProfileOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, name])
  @@index([ownerId, archivedAt])
}

model StoryWaypointBinding {
  id                          String                @id @default(cuid())
  storyId                     String
  blockId                     String                @unique
  waypointId                  String
  waypointVersionId           String
  runtimeMode                 String                @default("DEVELOPMENT_MOCK")
  scanInteraction             String                @default("{}")
  successEvent                String                @default("vision.verification_succeeded")
  retryMessageConfiguration   String                @default("{}")
  failureMessageConfiguration String                @default("{}")
  captainFallbackPolicy       String                @default("{}")
  offlineBehavior             String                @default("CAPTAIN_FALLBACK")
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  story                       TallTale              @relation(fields: [storyId], references: [id], onDelete: Cascade)
  block                       StoryBlock            @relation(fields: [blockId], references: [id], onDelete: Cascade)
  waypoint                    VisionWaypoint        @relation(fields: [waypointId], references: [id], onDelete: Restrict)
  waypointVersion             VisionWaypointVersion @relation(fields: [waypointVersionId], references: [id], onDelete: Restrict)

  @@index([storyId, waypointVersionId])
  @@index([waypointId, updatedAt])
}

model VerificationAttempt {
  id                      String                          @id @default(cuid())
  storyId                 String
  stageId                 String
  playerId                String?
  sessionId               String?
  verificationRequestId   String?
  waypointId              String
  waypointVersionId       String
  attemptState            String                          @default("IDLE")
  result                  String?
  guidanceCode            String?
  evidenceDigest          String?
  platform                String
  adapterType             String
  eventDeliveryStatus     String                          @default("NOT_DELIVERED")
  captainAction           String?
  mockScenario            String?
  protocolVersion         String                          @default("1.0")
  protocolMessageId       String?
  idempotencyKey          String                          @unique
  staleResultRejected     Boolean                         @default(false)
  duplicateResultRejected Boolean                         @default(false)
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  startedAt               DateTime?
  completedAt             DateTime?
  closedAt                DateTime?
  story                   TallTale                        @relation(fields: [storyId], references: [id], onDelete: Restrict)
  session                 TaleSession?                    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  player                  PlayerProfile?                  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  verificationRequest     TaleVerificationRequest?        @relation(fields: [verificationRequestId], references: [id], onDelete: SetNull)
  waypoint                VisionWaypoint                  @relation(fields: [waypointId], references: [id], onDelete: Restrict)
  waypointVersion         VisionWaypointVersion           @relation(fields: [waypointVersionId], references: [id], onDelete: Restrict)
  transitions             VerificationAttemptTransition[]
  evidenceBundles         VisionEvidenceBundle[]

  @@index([sessionId, stageId, createdAt])
  @@index([waypointVersionId, result, createdAt])
  @@index([playerId, attemptState, createdAt])
  @@index([verificationRequestId])
}

model VerificationAttemptTransition {
  id        String              @id @default(cuid())
  attemptId String
  sequence  Int
  fromState String?
  toState   String
  metadata  String              @default("{}")
  createdAt DateTime            @default(now())
  attempt   VerificationAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, sequence])
  @@index([attemptId, createdAt])
}

model VisionEvidenceBundle {
  id               String              @id @default(cuid())
  attemptId        String
  metadata         String              @default("{}")
  retentionPolicy  String              @default("DERIVED_ONLY")
  storageReference String?
  contentHash      String?
  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  deletedAt        DateTime?
  attempt          VerificationAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId, createdAt])
  @@index([expiresAt, deletedAt])
}

model CompanionDevice {
  id              String           @id @default(cuid())
  ownerId         String
  displayName     String
  instanceId      String           @unique
  protocolVersion String
  capabilities    String           @default("{}")
  lastSeenAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime         @default(now())
  owner           GameMasterUser   @relation("CompanionDeviceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  pairingSessions PairingSession[]

  @@index([ownerId, revokedAt, lastSeenAt])
}

model PairingSession {
  id                String          @id @default(cuid())
  ownerId           String
  companionDeviceId String
  pairingCodeHash   String          @unique
  sessionSecretHash String          @unique
  allowedOrigin     String
  expiresAt         DateTime
  pairedAt          DateTime?
  revokedAt         DateTime?
  createdAt         DateTime        @default(now())
  owner             GameMasterUser  @relation("PairingSessionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  companionDevice   CompanionDevice @relation(fields: [companionDeviceId], references: [id], onDelete: Cascade)

  @@index([ownerId, expiresAt, revokedAt])
  @@index([companionDeviceId, expiresAt])
}
