/// Immutable, rerunnable provenance for a legacy Companion record imported
/// into the Chronicle domain. This is the only legacy-to-canonical ID map.
model LegacyEntityReference {
  id               String    @id @default(cuid())
  sourceDomain     String
  sourceModel      String
  sourceId         String
  canonicalModel   String
  canonicalId      String
  migrationVersion String
  sourceChecksum   String
  migratedAt       DateTime  @default(now())
  verifiedAt       DateTime?

  @@unique([sourceDomain, sourceModel, sourceId, canonicalModel, migrationVersion])
  @@index([canonicalModel, canonicalId])
  @@index([sourceDomain, sourceModel, sourceId])
}

/// Records each migration attempt without retaining private source payloads.
model LegacyMigrationRun {
  id               String    @id @default(cuid())
  migrationVersion String
  mode             String
  status           String
  sourceSelector   String?
  report           String    @default("{}")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([migrationVersion, startedAt])
  @@index([status, startedAt])
}

/// Privacy-safe, best-effort evidence that a retained legacy doorway was used.
/// It deliberately contains canonical IDs only and never request or credential
/// material; failures to write this table cannot affect the canonical action.
model CompatibilityObservation {
  id                 String   @id @default(cuid())
  correlationId      String
  operation          String
  routeKey           String
  disposition        String
  canonicalSessionId String?
  canonicalAccountId String?
  testTraffic        Boolean  @default(false)
  occurredAt         DateTime @default(now())

  @@index([operation, occurredAt])
  @@index([canonicalSessionId, occurredAt])
  @@index([correlationId])
}

