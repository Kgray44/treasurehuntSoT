  owner             CommunityProfile                @relation("CommunityListingOwner", fields: [ownerProfileId], references: [id], onDelete: Restrict)
  currentRelease    CommunityRelease?               @relation("CommunityListingCurrentRelease", fields: [currentReleaseId], references: [id], onDelete: SetNull)
  releases          CommunityRelease[]              @relation("CommunityListingReleases")
  declarations      CommunityOwnershipDeclaration[]

  @@index([ownerProfileId, updatedAt])
  @@index([publicationStatus, visibility])
}

model CommunityRelease {
  id                           String                          @id @default(cuid())
  listingId                    String
  semanticVersion              String
  manifestSchemaVersion        Int                             @default(1)
  minimumPlatformVersion       String?
  sourcePublishedTaleVersionId String?
  manifest                     String
  manifestChecksum             String
  packageChecksum              String?
  releaseNotes                 String?
  compatibility                String                          @default("{}")
  licenseSnapshot              String
  attributionSnapshot          String                          @default("[]")
  spoilerSnapshot              String                          @default("{}")
  moderationStatus             String                          @default("ACTIVE")
  publishedByProfileId         String
  publishedAt                  DateTime                        @default(now())
  deprecatedAt                 DateTime?
  replacementReleaseId         String?
  createdAt                    DateTime                        @default(now())
  listing                      CommunityListing                @relation("CommunityListingReleases", fields: [listingId], references: [id], onDelete: Restrict)
  currentForListing            CommunityListing?               @relation("CommunityListingCurrentRelease")
  sourcePublishedTaleVersion   PublishedTaleVersion?           @relation("CommunityReleaseSource", fields: [sourcePublishedTaleVersionId], references: [id], onDelete: Restrict)
  publishedBy                  CommunityProfile                @relation("CommunityReleasePublisher", fields: [publishedByProfileId], references: [id], onDelete: Restrict)
  attributions                 CommunityReleaseAttribution[]
  declarations                 CommunityOwnershipDeclaration[]
  assets                       CommunityAssetReference[]

  @@unique([listingId, semanticVersion])
  @@index([listingId, publishedAt])
  @@index([sourcePublishedTaleVersionId])
}

model CommunityReleaseAttribution {
  id                  String            @id @default(cuid())
  releaseId           String
  creditedProfileId   String?
  creditedDisplayName String
  contributionType    String
  sourceUrl           String?
  requiredCreditText  String?
  licenseReference    String?
  sortOrder           Int
  createdAt           DateTime          @default(now())
  release             CommunityRelease  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  creditedProfile     CommunityProfile? @relation(fields: [creditedProfileId], references: [id], onDelete: SetNull)

  @@index([releaseId, sortOrder])
}

model CommunityOwnershipDeclaration {
  id                 String            @id @default(cuid())
  listingId          String
  releaseId          String?
  declarantProfileId String
  declarationVersion Int
  acceptedStatements String
  evidenceReferences String            @default("[]")
  createdAt          DateTime          @default(now())
  listing            CommunityListing  @relation(fields: [listingId], references: [id], onDelete: Restrict)
  release            CommunityRelease? @relation(fields: [releaseId], references: [id], onDelete: Restrict)
  declarant          CommunityProfile  @relation(fields: [declarantProfileId], references: [id], onDelete: Restrict)

  @@index([listingId, releaseId])
}

model CommunityAssetReference {
  id               String            @id @default(cuid())
  ownerProfileId   String
  releaseId        String?
  checksum         String
  declaredMimeType String
  detectedMimeType String?
  fileSize         Int
  storageProvider  String
  storageKey       String            @unique
  visibility       String            @default("PRIVATE")
  scanStatus       String            @default("SCAN_NOT_CONFIGURED")
  processingStatus String            @default("UPLOADED")
  accessibility    String            @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  removedAt        DateTime?
  owner            CommunityProfile  @relation(fields: [ownerProfileId], references: [id], onDelete: Restrict)
  release          CommunityRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@unique([ownerProfileId, checksum])
  @@index([releaseId, visibility])
}

model CommunityOutboxEvent {
  id                String    @id @default(cuid())
  eventType         String
  aggregateType     String
  aggregateId       String
  payloadVersion    Int       @default(1)
  payload           String
  idempotencyKey    String    @unique
  availableAt       DateTime  @default(now())
  claimedAt         DateTime?
  claimOwner        String?
  claimExpiresAt    DateTime?
  processedAt       DateTime?
  attemptCount      Int       @default(0)
  maxAttempts       Int       @default(5)
  terminalFailureAt DateTime?
  failureCode       String?
  createdAt         DateTime  @default(now())

  @@index([processedAt, availableAt, claimExpiresAt])
  @@index([aggregateType, aggregateId, createdAt])
}

model CommunityLicensePolicy {
  id                   String   @id @default(cuid())
  key                  String   @unique
  displayName          String
  policyVersion        Int      @default(1)
  allowsPrivateUse     Boolean  @default(true)
  allowsPublicUse      Boolean  @default(false)
  allowsModification   Boolean  @default(false)
  allowsRedistribution Boolean  @default(false)
  allowsCommercialUse  Boolean  @default(false)
  requiresAttribution  Boolean  @default(true)
  requiresSourceLink   Boolean  @default(false)
  shareAlike           Boolean  @default(false)
  customTerms          String?
  termsUrl             String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
