# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/node_modules.failed
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local data, generated Prisma client state, and backups
*.db
*.db-journal
*.sqlite*
!prisma/schema.sqlite.prisma
/backups/

# local startup state and runtime mirrors
/.forever-dev.json
/.forever-lock.sha
/.runtime/

# browser and visual test artifacts
/test-results/
/playwright-report/
/playwright/.auth/
/artifacts/screenshots/
/artifacts/validation/

# local certificates, archives, logs, and editor state
*.key
*.crt
*.pfx
*.log
*.zip
*.tar.gz
.idea/
.vscode/
Thumbs.db
__pycache__/
*.py[cod]

# private conversation imports and local synchronization state
/Codex_Chats/imports/*
!/Codex_Chats/imports/README.md
!/Codex_Chats/imports/.gitkeep
/.codex/chat-sync-cache/
/.codex/*.lock
/Codex_Chats/**/*.tmp
/Codex_Chats/**/*.bak
/Codex_Chats/imports/**/temp*/
/Codex_Chats/imports/**/extracted*/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
