{
  "name": "forever-treasure-companion",
  "version": "0.5.0-b3",
  "description": "Shared Player, Captain, and Studio companion for versioned Tall Tales.",
  "author": "The Forever Treasure contributors",
  "private": true,
  "main": "apps/desktop/main.cjs",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "assets:validate": "tsx scripts/validate-animation-assets.ts",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-all.ps1",
    "dev:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "db:generate": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.sqlite.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:preset": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force --schema prisma/schema.sqlite.prisma",
    "db:generate:mysql": "prisma generate --schema prisma/schema.prisma",
    "db:migrate:mysql:init": "prisma db execute --file prisma/mysql-migrations/0001_init/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:companion": "prisma db execute --file prisma/mysql-migrations/0002_player_companion_shell/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:command-center": "prisma db execute --file prisma/mysql-migrations/0002_game_master_command_center/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:studio": "prisma db execute --file prisma/mysql-migrations/0003_tall_tale_studio_phase1/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:platform": "prisma db execute --file prisma/mysql-migrations/0004_tall_tale_platform/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:vision": "prisma db execute --file prisma/mysql-migrations/0005_vision_waypoint_b1/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:capture": "prisma db execute --file prisma/mysql-migrations/0006_vision_capture_b2/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:authoring": "prisma db execute --file prisma/mysql-migrations/0007_vision_studio_authoring_b3/migration.sql --schema prisma/schema.prisma",
    "desktop:dev": "concurrently --kill-others-on-fail \"npm:dev\" \"wait-on http://127.0.0.1:3000 && electron apps/desktop/main.cjs\"",
    "desktop:stage": "node scripts/prepare-desktop.mjs",
    "desktop:build": "npm run build && npm run desktop:stage && electron-builder --win nsis",
    "desktop:smoke": "node scripts/desktop-smoke.mjs",
    "desktop:test": "node --test apps/desktop/desktop-shell.test.cjs",
    "companion:test": "node --test apps/companion/*.test.cjs",
    "companion:electron-smoke": "electron apps/companion/electron-capture-smoke.cjs",
    "companion:hotkey-smoke": "node apps/companion/windows-hotkey-smoke.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@gsap/react": "2.1.2",
    "@prisma/client": "6.19.3",
    "@rive-app/react-webgl2": "4.29.5",
    "bcryptjs": "3.0.2",
    "gsap": "3.15.0",
    "lottie-web": "5.13.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "page-flip": "2.0.7",
    "pino": "10.1.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "8.21.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^20",
    "@types/qrcode": "1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "9.2.4",
    "electron": "41.10.2",
    "electron-builder": "26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.2.0",
    "prettier": "3.6.2",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "4.20.6",
    "typescript": "^5",
    "vitest": "4.1.10",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "build": {
    "appId": "com.forevertreasure.companion",
    "productName": "The Forever Treasure Companion",
    "asar": true,
    "files": [
      "apps/desktop/**/*.cjs",
      "apps/companion/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".desktop-bundle/app-server",
        "to": "app-server"
      },
      {
        "from": ".desktop-bundle/app-server/node_modules",
        "to": "app-server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "apps/companion/windows-hotkey-monitor.ps1",
        "to": "companion/windows-hotkey-monitor.ps1"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
