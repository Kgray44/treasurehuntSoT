{
  "name": "forever-treasure-companion",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "language:validate": "tsx scripts/validate-user-facing-language.ts",
    "test:e2e": "playwright test",
    "assets:validate": "tsx scripts/validate-animation-assets.ts",
    "private-content:scan": "tsx scripts/private-content/scan.ts",
    "private-content:build-scan": "tsx scripts/private-content/build-scan.ts",
    "private-content:staged-diff-scan": "tsx scripts/private-content/staged-diff-scan.ts",
    "private-content:verify-fixtures": "tsx scripts/private-content/verify-fixtures.ts",
    "private-content:inspect": "tsx scripts/private-content/cli.ts inspect",
    "private-content:verify": "tsx scripts/private-content/cli.ts verify",
    "private-content:import-dry-run": "tsx scripts/private-content/cli.ts import-dry-run",
    "private-content:import-commit": "tsx scripts/private-content/cli.ts import-commit",
    "private-content:export": "tsx scripts/private-content/cli.ts export",
    "private-content:backup": "tsx scripts/private-content/cli.ts backup",
    "private-content:restore-verify": "tsx scripts/private-content/cli.ts restore-verify",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-all.ps1",
    "dev:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "db:generate": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.sqlite.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:preset": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force --schema prisma/schema.sqlite.prisma",
    "db:generate:mysql": "prisma generate --schema prisma/schema.prisma",
    "db:migrate:mysql:init": "prisma db execute --file prisma/mysql-migrations/0001_init/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:companion": "prisma db execute --file prisma/mysql-migrations/0002_player_companion_shell/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:command-center": "prisma db execute --file prisma/mysql-migrations/0002_game_master_command_center/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:studio": "prisma db execute --file prisma/mysql-migrations/0003_tall_tale_studio_phase1/migration.sql --schema prisma/schema.prisma",
    "db:migrate:mysql:platform": "prisma db execute --file prisma/mysql-migrations/0004_tall_tale_platform/migration.sql --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@gsap/react": "2.1.2",
    "@prisma/client": "6.19.3",
    "@rive-app/react-webgl2": "4.29.5",
    "bcryptjs": "3.0.2",
    "gsap": "3.15.0",
    "lottie-web": "5.13.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "page-flip": "2.0.7",
    "pino": "10.1.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^20",
    "@types/qrcode": "1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "27.2.0",
    "prettier": "3.6.2",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "4.20.6",
    "typescript": "^5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
