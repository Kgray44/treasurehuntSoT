# Copy to .env for local development. Values below are non-production placeholders.
DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-at-least-32-random-bytes"
GM_USERNAME="kato"
GM_PASSWORD="replace-with-a-local-development-password"
PLAYER_ACCESS_CODE="replace-with-a-private-development-code"
PLAYER_USERNAME="sera"
PLAYER_PASSWORD="replace-with-a-local-player-password"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"
PROJECT_ONE_VOYAGE_STAGE="F_COMPATIBILITY_ONLY"
# Optional absolute path for a durable asset volume. Omit to use .data/chronicle-assets.
# CHRONICLE_ASSET_ROOT="D:\ForeverTreasureAssets"
CHRONICLE_MAX_UPLOAD_MB="25"
# Absolute paths outside this repository, public/, .next/, and source directories.
# Private package keys/passphrases are never environment defaults or browser-visible values.
PRIVATE_CONTENT_ROOT="D:\\ForeverTreasurePrivateContent"
PRIVATE_CONTENT_STAGING_ROOT="D:\\ForeverTreasurePrivateStaging"
PRIVATE_CONTENT_MAX_PACKAGE_BYTES="33554432"
PRIVATE_CONTENT_MAX_PLAINTEXT_BYTES="50331648"
PRIVATE_CONTENT_MAX_ASSET_BYTES="25165824"
PRIVATE_CONTENT_MAX_FILE_COUNT="256"
PRIVATE_CONTENT_IMPORT_ENABLED="true"
