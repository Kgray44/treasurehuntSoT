# Copy to .env for local development. Values below are non-production placeholders.
DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-at-least-32-random-bytes"
GM_USERNAME="kato"
GM_PASSWORD="replace-with-a-local-development-password"
PLAYER_ACCESS_CODE="replace-with-a-private-development-code"
PLAYER_USERNAME="sera"
PLAYER_PASSWORD="replace-with-a-local-player-password"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"
# Pilot-only B-4 local engine flags. Keep automatic progression disabled.
# FEATURE_VISION_BUILD_ENGINE="true"
# FEATURE_VISION_RUNTIME_ENGINE="true"
# FEATURE_VISION_RECONSTRUCTION="true"
# FEATURE_VISION_SECONDARY_MATCHER="true"
# FEATURE_SHADOW_VERIFICATION="true"
# Phase B-5 Player, story, and Captain integration. These are independent rollback switches.
# FEATURE_LIVE_EXTERNAL_AR="true"
# FEATURE_VISION_PLAYER_STORY_INTEGRATION="true"
# FEATURE_VISION_CAPTAIN_INTEGRATION="true"
# FEATURE_VISION_OFFLINE_RECONCILIATION="true"
# Optional dedicated HMAC secret; otherwise SESSION_SECRET is used. Use at least 32 random bytes.
# VISION_STAGE_TOKEN_SECRET="replace-with-at-least-32-random-bytes"
# Automatic progression must remain disabled until the B-4/B-5 field-evidence gates pass.
# FEATURE_AUTOMATIC_VISION_PROGRESSION="false"
# Optional absolute path for a durable asset volume. Omit to use .data/tall-tale-assets.
# TALL_TALE_ASSET_ROOT="D:\ForeverTreasureAssets"
TALL_TALE_MAX_UPLOAD_MB="25"
