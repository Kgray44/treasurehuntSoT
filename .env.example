# Copy to .env for local development. Values below are non-production placeholders.
DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-at-least-32-random-bytes"
GM_USERNAME="kato"
GM_PASSWORD="replace-with-a-local-development-password"
PLAYER_ACCESS_CODE="replace-with-a-private-development-code"
PLAYER_USERNAME="sera"
PLAYER_PASSWORD="replace-with-a-local-player-password"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"
# Optional absolute path for a durable asset volume. Omit to use .data/tall-tale-assets.
# TALL_TALE_ASSET_ROOT="D:\ForeverTreasureAssets"
TALL_TALE_MAX_UPLOAD_MB="25"
# Harborlight is internal-only in Phase 1. Do not enable public publishing.
COMMUNITY_ENABLED="true"
COMMUNITY_PUBLIC_PUBLISHING_ENABLED="false"
COMMUNITY_MODERATION_REQUIRED="true"
COMMUNITY_ASSET_STORAGE_PROVIDER="local"
# COMMUNITY_ASSET_ROOT="D:\\ForeverTreasureCommunityAssets"
COMMUNITY_WORKER_ENABLED="false"
COMMUNITY_RATE_LIMIT_PROFILE="10"
# COMMUNITY_PUBLIC_BASE_URL="http://127.0.0.1:3000"
