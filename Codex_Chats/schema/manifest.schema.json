{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Kgray44/treasurehuntSoT/blob/main/Codex_Chats/schema/manifest.schema.json",
  "title": "Forever Treasure conversation archive manifest",
  "type": "object",
  "required": [
    "schema_version",
    "synchronizer_version",
    "project_identity",
    "last_successful_synchronization_at",
    "total_conversation_count",
    "total_message_count",
    "source_coverage",
    "warnings",
    "migration_history",
    "conversations"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "synchronizer_version": { "type": "string" },
    "project_identity": { "type": "object" },
    "last_successful_synchronization_at": { "type": ["string", "null"] },
    "total_conversation_count": { "type": "integer", "minimum": 0 },
    "total_message_count": { "type": "integer", "minimum": 0 },
    "source_coverage": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "migration_history": { "type": "array" },
    "conversations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "conversation_id", "source_type", "source_identifier", "project_identifier",
          "title", "archive_path", "created_at", "updated_at", "first_archived_at",
          "last_synchronized_at", "message_count", "content_sha256", "source_sha256",
          "status", "redactions"
        ],
        "properties": {
          "conversation_id": { "type": "string", "minLength": 1 },
          "source_type": { "enum": ["codex_session", "chatgpt_export", "explicit_transcript"] },
          "source_identifier": { "type": "string" },
          "project_identifier": { "type": "string" },
          "title": { "type": "string" },
          "archive_path": { "type": "string", "pattern": "^Codex_Chats/chats/[A-Za-z0-9._-]+\\.md$" },
          "created_at": { "type": ["string", "null"] },
          "updated_at": { "type": ["string", "null"] },
          "first_archived_at": { "type": "string" },
          "last_synchronized_at": { "type": "string" },
          "message_count": { "type": "integer", "minimum": 0 },
          "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "status": { "enum": ["active", "unavailable", "archived"] },
          "redactions": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
